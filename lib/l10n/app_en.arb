{
  "pageTitle": "Localization Demo",
  "@pageTitle": {
    "description": "Page title"
  },
  "currentLocale": "Current locale: {locale}",
  "@currentLocale": {
    "description": "Display current locale",
    "placeholders": {
      "locale": {
        "type": "String",
        "example": "en"
      }
    }
  },
  "greeting": "Hello, {name}!",
  "@greeting": {
    "description": "Greeting with name",
    "placeholders": {
      "name": {
        "type": "String",
        "example": "John"
      }
    }
  },
  "itemCount": "You have {count} messages",
  "@itemCount": {
    "description": "Message count",
    "placeholders": {
      "count": {
        "type": "int",
        "example": "5"
      }
    }
  },
  "switchToEn": "Switch to English",
  "@switchToEn": {
    "description": "Switch to English button"
  },
  "switchToZh": "Switch to Chinese",
  "@switchToZh": {
    "description": "Switch to Chinese button"
  },
  "demoDescription": "This page demonstrates flutter gen-l10n. Translations are defined in .arb files, and Dart code is generated by running flutter gen-l10n.",
  "@demoDescription": {
    "description": "Demo description"
  }
}
