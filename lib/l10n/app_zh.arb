        "example": "张三"
      }
    }
  },
  "itemCount": "你有 {count} 条消息",
  "@itemCount": {
    "description": "消息数量",
    "placeholders": {
      "count": {
        "type": "int",
        "example": "5"
      }
    }
  },
  "switchToEn": "切换到英文",
  "@switchToEn": {
    "description": "切换到英文按钮"
  },
  "switchToZh": "切换到中文",
  "@switchToZh": {
    "description": "切换到中文按钮"
  },
